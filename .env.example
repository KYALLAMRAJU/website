# ============================================================
# .env.example — Copy this to .env for local development
# ============================================================
# Usage:
#   cp .env.example .env
#   Edit .env with your own values
#   NEVER commit .env to git (it is in .gitignore)
#
# For production, see deploy/06-TEMPLATES/.env.prod.template
# ============================================================

# ── Django Core ────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-replace-me-with-a-real-random-key

DEBUG=True

# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=127.0.0.1,localhost

# Comma-separated list of trusted CSRF origins
CSRF_TRUSTED_ORIGINS=http://localhost,http://localhost:8000,http://127.0.0.1,http://127.0.0.1:8000

# ── Database (local dev uses SQLite by default when DEBUG=True) ─
# Leave these blank locally — settings.py will use SQLite automatically when DEBUG=True.
# DB_NAME=advaitam_db
# DB_USER=advaitam_user
# DB_PASSWORD=devpassword123
# DB_HOST=localhost
# DB_PORT=5432

# ── Storage (set to False in dev — files served from local disk) ─
USE_S3=False

# ── AWS S3 + CloudFront (only needed when USE_S3=True) ────────
# AWS_STORAGE_BUCKET_NAME=your-s3-bucket-name
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=xxxxxxxxxxxx.cloudfront.net
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Email (dev: console backend — emails print to terminal) ──
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com
ADMIN_EMAIL=your-email@example.com

# ── AWS SES (only needed in production) ──────────────────────
# AWS_SES_REGION_NAME=us-east-1

# ── Session ───────────────────────────────────────────────────
SESSION_COOKIE_AGE=86400
SESSION_EXPIRE_AT_BROWSER_CLOSE=False

# ── CORS ─────────────────────────────────────────────────────
# In dev (DEBUG=True), CORS_ALLOW_ALL_ORIGINS=True is set automatically in settings.py
# No extra config needed here for local development.

# ── Content Security Policy (CSP) ────────────────────────────
# Only set this if you have a CloudFront domain (optional in dev)
# CSP_CLOUDFRONT_DOMAIN=xxxxxxxxxxxx.cloudfront.net

# ── Redis (optional in dev — uses in-memory cache if blank) ──
# REDIS_URL=redis://localhost:6379/0

# ── Sentry Error Tracking (optional — leave blank to disable) ─
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# ── CloudFront Origin Secret (only needed in production) ─────
# CLOUDFRONT_SECRET=your-secret-header-value

# ── Anthropic Claude AI (optional) ───────────────────────────
# ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Security (dev: these are relaxed automatically by DEBUG=True) ─
SECURE_SSL_REDIRECT=False

